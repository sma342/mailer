name: email-templates
description: Skill wspierający tworzenie i testowanie szablonów email
topics:
  - email
  - templates
  - html
  - text
  - jinja
applyTo:
  - path: "**/templates/**"
  - path: "**/*template*.py"
languageDetection:
  preferredLanguage: python
  patterns:
    - "template"
    - "jinja"
    - "mailer"
